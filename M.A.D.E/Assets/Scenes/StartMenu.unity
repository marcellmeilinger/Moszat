  m_Name: 
  m_EditorClassIdentifier: SajatJatek::IntroManager
  storyPanel: {fileID: 67021564}
  storyText: {fileID: 853578746}
  sentences:
  - 'The Kingdom has fallen into shadow... Alaric, you are the last loyal knight
    of a broken realm. Only your blade can defy the darkness '
  - The Skeleton King has abducted the Princess, whisking her away to his seat of
    power deep within the haunted lands.
  - Your path lies through the Shadowy Forest, down into the Cursed Mines, and finally
    to the gates of the Black Fortress.
  - Face the undead legions, shatter the tyrant's magical crown, and restore peace
    to our World
  - Go now, Knight! Our fate rests in your hands...
  typingSpeed: 0.05
  typewriterSource: {fileID: 530051841}
